{
  "tasks": {
    "dev": "SNOWBALL_DEV_URL=http://localhost:5173 deno desktop --allow-read --allow-write --allow-env --allow-net main.ts",
    "dev:vite": "npm run dev",
    "test": "deno test --allow-read --allow-write --allow-env engine/",
    "build:frontend": "npm run build",
    "build": "npm run build && deno desktop --allow-read --allow-write --allow-env --allow-net --output dist/Snowball.exe main.ts"
  },
  "desktop": {
    "app": {
      "name": "Snowball",
      "identifier": "com.snowball.app",
      "icons": {
        "windows": "./icons/icon.ico",
        "linux": "./icons/icon.png"
      }
    }
  },
  "imports": {
    "jsr:@std/yaml": "jsr:@std/yaml@^1",
    "jsr:@std/http/file-server": "jsr:@std/http@^1/file-server",
    "jsr:@std/assert": "jsr:@std/assert@^1"
  }
}
